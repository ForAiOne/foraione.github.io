    <!-- Notification Toast -->
    <div id="toast" style="position: fixed; bottom: 20px; right: 20px; background: var(--color-primary); color: white; padding: 15px 25px; border-radius: 4px; transform: translateY(150%); transition: transform 0.3s ease; z-index: 2000;">
        Message envoyé !
    </div>

    <!-- JavaScript Interactions -->
	<script>
    // Configuration des noms chronologiques
    const nameSequence = [
        { text: "Desastrax", effect: "shatter" },
        { text: "Soul Famous Carpet", effect: "burn" },
        { text: "Rock'n Chair", effect: "shatter" },
        { text: "Explicit", effect: "burn" },
        { text: "No Mug", effect: "shatter" },
        { text: "Helium", effect: "burn" },
        { text: "Jar", effect: "shatter" },
        { text: "Codeine", effect: "burn" },
		{ text: "Wow", effect: "shatter" },
        { text: "Crumble head", effect: "burn" },
        { text: "Du garage à la scène", effect: "reborn" }

    ];

    let currentIndex = 0;
    const container = document.getElementById('name-evolution-container');

    function createSparks() {
        // Crée des particules (étincelles) au centre de l'écran
        for (let i = 0; i < 20; i++) {
            const spark = document.createElement('div');
            spark.classList.add('particle');
            
            spark.style.left = '50%';
            spark.style.top = '50%';
            
            const angle = Math.random() * Math.PI * 2;
            const velocity = 50 + Math.random() * 100;
            const tx = Math.cos(angle) * velocity;
            const ty = Math.sin(angle) * velocity;

            document.body.appendChild(spark);
            
            const animation = spark.animate([
                { transform: 'translate(-50%, -50%) scale(1)', opacity: 1 },
                { transform: `translate(calc(-50% + ${tx}px), calc(-50% + ${ty}px)) scale(0)`, opacity: 0 }
            ], {
                duration: 800 + Math.random() * 400,
                easing: 'cubic-bezier(0, .9, .57, 1)'
            });

            animation.onfinish = () => spark.remove();
        }
    }

    function playNextName() {
        if (currentIndex >= nameSequence.length) return;

        const data = nameSequence[currentIndex];
        const el = document.createElement('div');
        el.textContent = data.text;
        el.classList.add('evolution-text');

        // 1. Apparition initiale
        el.style.opacity = '1';
        
        // Ajustement de la taille de police pour les très longs noms
        if (data.text.length > 12) {
            el.style.fontSize = "3.5rem";
        }

        container.appendChild(el);

        // 2. Lancer l'effet après un court délai (Accéléré pour 9 noms)
        const displayTime = 1200; // Le texte reste 1.2 sec
        const animTime = 800;     // L'anim dure 0.8 sec

        setTimeout(() => {
            if (data.effect === 'shatter') {
                el.classList.add('anim-shatter');
                createSparks();
            } else if (data.effect === 'burn') {
                el.classList.add('anim-burn');
            } else if (data.effect === 'reborn') {
                el.classList.add('anim-reborn');
            }

            // 3. Passer au suivant après l'animation
            setTimeout(() => {
                if (data.effect !== 'reborn') {
                    el.remove();
                    currentIndex++;
                    playNextName();
                }
            }, animTime); 

        }, displayTime);
    }

    // Lancer l'animation au chargement
    window.addEventListener('load', () => {
        setTimeout(playNextName, 500);
    });
</script>
	
    <script>
        function toggleMenu() {
            const navLinks = document.getElementById('navLinks');
            navLinks.classList.toggle('active');
        }

        function playTeaser() {
            const btn = event.currentTarget;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Chargement...';
            
            setTimeout(() => {
                showNotification("Lancement de la vidéo du teaser (Simulation)");
                btn.innerHTML = originalText;
            }, 1000);
        }

        function showNotification(message = "Message envoyé avec succès !") {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.style.transform = "translateY(0)";
            
            setTimeout(() => {
                toast.style.transform = "translateY(150%)";
            }, 3000);
        }

        window.addEventListener('scroll', () => {
            let current = '';
            const sections = document.querySelectorAll('section');
            
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                const sectionHeight = section.clientHeight;
                if (scrollY >= (sectionTop - 150)) {
                    current = section.getAttribute('id');
                }
            });

            document.querySelectorAll('.nav-links a').forEach(a => {
                a.classList.remove('active');
                if (a.getAttribute('href').includes(current)) {
                    a.classList.add('active');
                }
            });
        });
    </script>

</body>
</html>